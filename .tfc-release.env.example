# Template for `op run --env-file=.tfc-release.env -- scripts/tfc-release.sh <VERSION>`.
# Copy to .tfc-release.env (gitignored), then run via op run.
#
# 1Password references resolve at runtime; nothing here is sensitive.

TFC_ORG=doc-ba

# A user/team token with registry-providers write permission.
TFC_TOKEN=op://Rashadnyk/Terraform Doc.ba/credential

# 40-char fingerprint of the signing key. The corresponding secret key
# must already be importable by gpg locally — `op item get` won't import
# it for you. Bootstrap with:
#   op read 'op://Rashadnyk/Aperature TFC Provider Signing Key/private_key' | gpg --import
GPG_KEY_ID=BAD4EF00D93B1D085303884B2BC79625479DED87
